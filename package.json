{
  "name": "kaigo-ide",
  "version": "0.1.0",
  "private": true,
  "description": "KaigoIDE - 居宅介護支援事業所向け総合業務支援システム",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean",
    "db:setup": "pnpm --filter @kaigo-ide/api db:generate && pnpm --filter @kaigo-ide/api db:migrate && pnpm --filter @kaigo-ide/api db:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@nestjs/core"
    ]
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  }
}
